# Bookwyrm launcher environment example

BOOKWYRM_HOME=C:\ProgramData\Bookwyrm
BOOKWYRM_LOG_DIR=C:\ProgramData\Bookwyrm\logs
BOOKWYRM_LAUNCH_URL=http://localhost:8090
BOOKWYRM_OPEN_BROWSER_ON_FIRST_START=true
BOOKWYRM_RESTART_LIMIT=5
BOOKWYRM_RESTART_WINDOW_SEC=300
BOOKWYRM_RESTART_BASE_DELAY_SEC=2
BOOKWYRM_RESTART_MAX_DELAY_SEC=30

# Optional explicit executable overrides
# BOOKWYRM_METADATA_EXE=C:\ProgramData\Bookwyrm\bin\metadata-service.exe
# BOOKWYRM_INDEXER_EXE=C:\ProgramData\Bookwyrm\bin\indexer-service.exe
# BOOKWYRM_BACKEND_EXE=C:\ProgramData\Bookwyrm\bin\backend.exe

# Service URLs consumed by app/backend
METADATA_SERVICE_URL=http://localhost:8080
INDEXER_SERVICE_URL=http://localhost:8091
APP_BACKEND_ADDR=:8090
UI_DIST_DIR=C:\ProgramData\Bookwyrm\web\dist

# app/backend runtime
LIBRARY_ROOT=D:\Media\Books
DOWNLOADS_COMPLETED_PATH=D:\Downloads\Completed
DATABASE_DSN=postgres://bookwyrm:bookwyrm@localhost:5432/bookwyrm_backend?sslmode=disable

# Optional download client integration (uncomment and set values as needed)
# qBittorrent
# QBITTORRENT_BASE_URL=http://localhost:8081
# QBITTORRENT_USERNAME=admin
# QBITTORRENT_PASSWORD=change-me
#
# SABnzbd
# SABNZBD_BASE_URL=http://localhost:8085
# SABNZBD_API_KEY=change-me
# SABNZBD_CATEGORY=books
#
# NZBGet
# NZBGET_BASE_URL=http://localhost:6789
# NZBGET_USERNAME=nzbget
# NZBGET_PASSWORD=change-me
# NZBGET_CATEGORY=books

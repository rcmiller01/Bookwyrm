# Copy to .env and adjust values as needed.

# Shared Postgres settings
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=bookwyrm
POSTGRES_PASSWORD=bookwyrm
POSTGRES_DB=bookwyrm

# Host port mappings
METADATA_PORT=8080
INDEXER_PORT=8091
APP_BACKEND_PORT=8090

# Service bind addresses inside containers
APP_BACKEND_ADDR=:8090
INDEXER_SERVICE_ADDR=:8091
